datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}
// Mantenha o restante dos models (Tenant, User, Task) como estão

// Tabela de Empresas (Os Tenants)
model Tenant {
  id    String @id @default(uuid())
  name  String
  users User[]
  tasks Task[]
  subtasks Subtask[]
}

// Tabela de Usuários
model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
}

// Tabela CRUD (Exemplo: Tarefas)
model Task {
  id        String @id @default(uuid())
  title     String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  subtasks  Subtask[]

  @@unique([id, tenantId])
}

// Subtarefas de uma Task (isoladas por tenant)
model Subtask {
  id        String @id @default(uuid())
  title     String
  done      Boolean @default(false)
  taskId    String
  tenantId  String

  // Garante que a subtarefa pertence ao mesmo tenant da task pai
  task      Task   @relation(fields: [taskId, tenantId], references: [id, tenantId])
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@index([taskId, tenantId])
}